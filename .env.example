MATCHPULSE_PUBLIC_URL=http://127.0.0.1:5173
MATCHPULSE_HOST=127.0.0.1
MATCHPULSE_API_PORT=8787
MATCHPULSE_CLIENT_PORT=5173
MATCHPULSE_SERVE_STATIC=
MATCHPULSE_DATA_PROVIDER=local
MATCHPULSE_STORAGE_PROVIDER=local
MATCHPULSE_STATE_ID=beta
MATCHPULSE_STORAGE_BUCKET=profile-photos
HOST=127.0.0.1
PORT=8787

# Zero-cost public beta path:
# Use Supabase Free for auth, state persistence, and photo storage.
# Leave OpenAI empty to keep the local AI heuristic and avoid paid API calls.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Optional paid upgrade. Leave blank for strict zero-cost mode.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini

# Optional email upgrade. Leave blank to save Sunday Briefings as in-app/local previews.
MATCHPULSE_EMAIL_PROVIDER=supabase
RESEND_API_KEY=
MATCHPULSE_FROM_EMAIL=MatchPulse <briefing@yourdomain.com>
MATCHPULSE_REQUIRE_EMAIL_VERIFICATION=0
MATCHPULSE_REQUIRE_EMAIL_DELIVERY=0
MATCHPULSE_ALLOW_EMAIL_VERIFICATION_PREVIEW=1
