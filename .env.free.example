MATCHPULSE_PUBLIC_URL=https://your-free-render-url.onrender.com
MATCHPULSE_DATA_PROVIDER=supabase
MATCHPULSE_STORAGE_PROVIDER=supabase
MATCHPULSE_STATE_ID=beta
MATCHPULSE_STORAGE_BUCKET=profile-photos
MATCHPULSE_SERVE_STATIC=1
HOST=0.0.0.0
PORT=10000

# Supabase Free project values.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
# Comma-separated providers only after they are enabled in Supabase Auth.
# Leave empty for the free beta fallback login buttons.
VITE_MATCHPULSE_OAUTH_PROVIDERS=

# Leave OpenAI empty for strict zero-cost AI.
OPENAI_API_KEY=

# Use Resend's free tier for real public-beta verification/reset emails.
# Set both require flags to 0 only for local preview-only testing.
RESEND_API_KEY=
MATCHPULSE_FROM_EMAIL=MatchPulse <briefing@yourdomain.com>
MATCHPULSE_REQUIRE_EMAIL_VERIFICATION=1
MATCHPULSE_REQUIRE_EMAIL_DELIVERY=1
